{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mizu",
  "version": "0.1.4",
  "identifier": "com.satoji.mizu",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://Sicazo.github.io/mizu/stable/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkgQjMxQzA3QkMyMjQ1NkY2MApSV1JnYjBVaXZBY2NzeUM3SExoUVI2RWg4MkVGODhqUlBsYXovYmt5SEdlQ0FCMHhuZEZaSS9XNwo="
    }
  },
  "app": {
    "windows": [
      {
        "title": "Mizu",
        "width": 1400,
        "height": 900,
        "minWidth": 480,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#F7F6F3",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
